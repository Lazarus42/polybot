{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "WriteRawAndManifests",
      "Effect": "Allow",
      "Action": ["s3:PutObject"],
      "Resource": "arn:aws:s3:::polybot-polymarket-sjgibson/*"
    },
    {
      "Sid": "ListBucket",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::polybot-polymarket-sjgibson"
    },
    {
      "Sid": "PublishHealthAlerts",
      "Effect": "Allow",
      "Action": ["sns:Publish"],
      "Resource": "arn:aws:sns:REGION:ACCOUNT_ID:polybot-alerts"
    }
  ]
}
